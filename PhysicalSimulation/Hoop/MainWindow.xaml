<Window x:Class="DrawingVisualApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrawingVisualApp"
        mc:Ignorable="d"
        Title="Rolling Hoop with Pendulum" Height="729" Width="1036">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <local:DrawingVisualClass x:Name="g1" Background="Black" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10"
                    HorizontalAlignment="Center" Background="#202020" Width="500" >
            <Button x:Name="btnReset" Content="Reset" Width="80"
                    Click="BtnReset_Click" Margin="5"/>
            <Button x:Name="btnPause" Content="Pause" Width="80"
                    Click="BtnPause_Click" Margin="5"/>
            <Separator Width="20" Visibility="Hidden"/>

            <TextBlock Text="Mass:" VerticalAlignment="Center"
                       Margin="10,0,5,0" Foreground="White"/>
            <Slider x:Name="sliderMass" Minimum="1" Maximum="20"
                    Value="10" Width="100"
                    ValueChanged="SliderMass_ValueChanged"/>
            <TextBlock x:Name="tbMassValue" Text="10.0" VerticalAlignment="Center"
                       Margin="10,0,20,0" Foreground="White" Width="40"/>

            <CheckBox x:Name="chkShowVectors" Content="Vectors"
                      VerticalAlignment="Center" Foreground="White"
                      Checked="ChkShowVectors_Checked"
                      Unchecked="ChkShowVectors_Checked"/>
        </StackPanel>
    </Grid>
</Window>