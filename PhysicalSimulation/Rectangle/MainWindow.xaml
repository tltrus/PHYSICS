<Window x:Class="DrawingVisualApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Particle Simulation" 
        Width="1200" 
        Height="700"
        Background="Black"
        SnapsToDevicePixels="False"
        UseLayoutRounding="True">

    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть - визуализация -->
        <Border Name="g" Margin="0,5,0,0" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Center" Width="990" Height="674" VerticalAlignment="Top">
            <Image Name="image" 
                   Stretch="None" 
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Правая часть - панель управления -->
        <Border Grid.Column="1" Margin="5" Background="#1E1E1E" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Заголовок -->
                    <TextBlock Text="Particle Simulation" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <!-- Информация о производительности -->
                    <Border Background="#2D2D30" Padding="8" CornerRadius="4" Margin="0,0,0,10">
                        <TextBlock Name="infoText" 
                                   Foreground="LightGreen" 
                                   FontFamily="Consolas" 
                                   FontSize="11"/>
                    </Border>

                    <!-- Разделитель -->
                    <Rectangle Height="1" Fill="Gray" Margin="0,5,0,10"/>

                    <!-- Параметры симуляции -->
                    <TextBlock Text="Simulation Parameters" 
                               Foreground="White" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <!-- PARTICLE_COUNT -->
                    <TextBlock Text="Particle Count:" 
                               Foreground="LightBlue" 
                               Margin="0,5,0,2"/>
                    <TextBlock Text="Range: 1 - 1000" 
                               Foreground="Gray" 
                               FontSize="10" 
                               Margin="0,0,0,5"/>
                    <TextBox Name="txtParticleCount" 
                             Text="100" 
                             Background="#3E3E42" 
                             Foreground="White" 
                             BorderBrush="#555555" 
                             Padding="3"/>

                    <!-- INTERACTION_RADIUS -->
                    <TextBlock Text="Interaction Radius:" 
                               Foreground="LightBlue" 
                               Margin="0,10,0,2"/>
                    <TextBlock Text="Range: 10 - 200" 
                               Foreground="Gray" 
                               FontSize="10" 
                               Margin="0,0,0,5"/>
                    <TextBox Name="txtInteractionRadius" 
                             Text="50" 
                             Background="#3E3E42" 
                             Foreground="White" 
                             BorderBrush="#555555" 
                             Padding="3"/>

                    <!-- VELOCITY_DAMPING -->
                    <TextBlock Text="Velocity Damping:" 
                               Foreground="LightBlue" 
                               Margin="0,10,0,2"/>
                    <TextBlock Text="Range: 0.9 - 1.0" 
                               Foreground="Gray" 
                               FontSize="10" 
                               Margin="0,0,0,5"/>
                    <TextBox Name="txtVelocityDamping" 
                             Text="0.995" 
                             Background="#3E3E42" 
                             Foreground="White" 
                             BorderBrush="#555555" 
                             Padding="3"/>

                    <!-- Разделитель -->
                    <Rectangle Height="1" Fill="Gray" Margin="0,15,0,10"/>

                    <!-- Кнопки управления -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Name="btnRestart" 
                                Content="Restart" 
                                Width="80" 
                                Height="30" 
                                Background="#0E639C" 
                                Foreground="White" 
                                BorderBrush="#555555" 
                                Margin="0,0,10,0"
                                Click="BtnRestart_Click"/>

                        <Button Name="btnPause" 
                                Content="Pause" 
                                Width="80" 
                                Height="30" 
                                Background="#4A4A4A" 
                                Foreground="White" 
                                BorderBrush="#555555"
                                Click="BtnPause_Click"/>
                    </StackPanel>

                    <!-- Статус симуляции -->
                    <TextBlock Name="txtStatus" 
                               Text="Simulation Running" 
                               Foreground="LightGreen" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0"/>

                    <!-- Подсказки -->
                    <Border Background="#252526" Padding="8" CornerRadius="4" Margin="0,20,0,0">
                        <TextBlock Text="Tip: Change parameters and click Restart to apply changes. Higher particle counts may affect performance." 
                                   Foreground="LightGray" 
                                   FontSize="10" 
                                   TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>