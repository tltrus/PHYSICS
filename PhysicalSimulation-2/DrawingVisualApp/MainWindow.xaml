<Window x:Class="DrawingVisualApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrawingVisualApp"
        mc:Ignorable="d"
        Title="Physics Simulation - Verlet Integration" Height="920" Width="1036"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">
    <Grid>
        <!-- Информационная панель и кнопки управления -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель управления сверху -->
            <Border Grid.Row="0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Информация об управлении -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#60FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                            <TextBlock FontSize="14">
                                <Run Text="Left Mouse Button: "/>
                                <Run Text="Drag platform left/right" FontWeight="Bold" />
                            </TextBlock>
                        </Border>

                        <Border Background="#60FFFFFF" CornerRadius="4" Padding="8,4">
                            <TextBlock FontSize="14">
                                <Run Text="Right Mouse Button: "/>
                                <Run Text="Create explosion" FontWeight="Bold"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnReset" Content="Reset Simulation" 
                                Background="#3A3A3A" Foreground="White" 
                                BorderBrush="#5A5A5A" Padding="12,6"
                                FontSize="14" FontWeight="Medium"
                                Click="BtnReset_Click" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основная область рендеринга -->
            <Grid Grid.Row="1">
                <Image x:Name="renderImage" HorizontalAlignment="Left" Width="1036" Height="830" VerticalAlignment="Top" RenderTransformOrigin="0.547,0.542" />
            </Grid>
        </Grid>
    </Grid>
</Window>